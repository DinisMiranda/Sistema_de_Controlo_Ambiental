# Server
PORT=3001
NODE_ENV=development

# MySQL — Docker (default compose): port 3307, password sca_root
# MySQL — Homebrew local: port 3306, use your real root password
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=sca_root
DB_NAME=sistema_controlo_ambiental2
DB_DIALECT=mysql
SYNC_MODELS=false

# Criada/promovida ao arranque se não existir nenhum admin (ex.: após import CSV)
BOOTSTRAP_ADMIN_EMAIL=admin@edificio.com
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_NAME=Administrador SCA

# JWT (when auth is implemented)
JWT_SECRET=change-me-in-production
