# Copy to scripts/.env (do not commit .env). Precedence: -n/--count > these vars > script defaults.
#
# NUM_UTILIZADORES — how many user rows to generate (integer >= 1). Default in code: 20.
NUM_UTILIZADORES=20
#
# UTILIZADORES_OUTPUT — path to the output text file (UTF-8; overwritten each run).
# Default if unset: scripts/generated/utilizadores_examination.txt (relative to scripts/).
# UTILIZADORES_OUTPUT=/absolute/or/relative/path/to/file.txt
