# Copy to scripts/.env (do not commit .env). Precedence: -n/--count > these vars > script defaults.
#
# NUM_UTILIZADORES — how many user rows to generate (integer >= 1). Default in code: 20.
NUM_UTILIZADORES=20
#
# UTILIZADORES_OUTPUT — path to the output CSV file (UTF-8; overwritten each run).
# Default if unset: scripts/generated/utilizadores_examination.csv (relative to scripts/).
# UTILIZADORES_OUTPUT=/absolute/or/relative/path/to/file.csv
#
# --- seed_casas.py ---
# NUM_CASAS — row count if you omit -n (default in code: 10).
# CASAS_OUTPUT — default scripts/generated/casas_examination.csv
#
# --- seed_casa_administradores.py ---
# NUM_CASA_ADMIN_PARES — how many (id_casa, id_utilizador) rows if you omit -n (default: 25).
# NUM_CASAS / NUM_UTILIZADORES — max id assumed after importing casas / utilizadores CSVs (defaults 10 / 20).
# CASA_ADMIN_OUTPUT — default scripts/generated/casa_administradores_examination.csv
#
# --- seed_sensores.py ---
# NUM_SENSORES — row count if you omit -n (default in code: 20).
# SENSORES_OUTPUT — default scripts/generated/sensores_examination.csv
#
# --- seed_atuadores.py ---
# NUM_ATUADORES — row count if you omit -n (default in code: 20).
# ATUADORES_OUTPUT — default scripts/generated/atuadores_examination.csv
#
# --- seed_acoes_sistema.py ---
# NUM_ACOES_SISTEMA — row count if you omit -n (default in code: 40).
# NUM_ATUADORES — max id_atuador if you omit --atuadores-csv / --max-atuador-id (default: 20).
# ACOES_SISTEMA_OUTPUT — default scripts/generated/acoes_sistema_examination.csv
#
# --- seed_parametros_automaticos.py ---
# NUM_PARAMETROS_AUTOMATICOS — row count if you omit -n (default in code: 35).
# NUM_ATUADORES — max atuadores_id_atuador if you omit --atuadores-csv / --max-atuador-id (default: 20).
# PARAMETROS_AUTOMATICOS_OUTPUT — default scripts/generated/parametros_automaticos_examination.csv
#
# --- seed_tipos.py ---
# NUM_TIPOS — how many rows from the built-in catalog (integer >= 1, max = 15).
# Default if unset: full catalog (4 sensores + 4 atuadores + 7 tipos Acao_sistema).
# NUM_TIPOS=15
#
# TIPOS_OUTPUT — output path for Tipos CSV (UTF-8; overwritten each run).
# Default: scripts/generated/tipos_examination.csv
# TIPOS_OUTPUT=/absolute/or/relative/path/to/tipos.csv
