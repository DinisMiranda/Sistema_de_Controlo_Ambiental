# Copy to scripts/.env (do not commit .env). Precedence: -n/--count > these vars > script defaults.
#
# NUM_UTILIZADORES — how many user rows to generate (integer >= 1). Default in code: 20.
NUM_UTILIZADORES=20
#
# UTILIZADORES_OUTPUT — path to the output CSV file (UTF-8; overwritten each run).
# Default if unset: scripts/generated/utilizadores_examination.csv (relative to scripts/).
# UTILIZADORES_OUTPUT=/absolute/or/relative/path/to/file.csv
#
# --- seed_tipos.py ---
# NUM_TIPOS — how many rows from the built-in catalog (integer >= 1, max = 15).
# Default if unset: full catalog (4 sensores + 4 atuadores + 7 tipos Acao_sistema).
# NUM_TIPOS=15
#
# TIPOS_OUTPUT — output path for Tipos CSV (UTF-8; overwritten each run).
# Default: scripts/generated/tipos_examination.csv
# TIPOS_OUTPUT=/absolute/or/relative/path/to/tipos.csv
